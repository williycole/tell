          "hunkStartOld": 0, "hunkStartNew": 1, "hunkLinesOld": 0, "hunkLinesNew": 55,
          "lines": [
            { "type": "add", "oldNum": null, "newNum": 1,  "text": "defmodule Stratum.Sources.HttpAdapter do" },
            { "type": "add", "oldNum": null, "newNum": 2,  "text": "  @behaviour Stratum.Sources.Adapter" },
            { "type": "add", "oldNum": null, "newNum": 3,  "text": "" },
            { "type": "add", "oldNum": null, "newNum": 4,  "text": "  @impl true" },
            { "type": "add", "oldNum": null, "newNum": 5,  "text": "  def fetch(%{settings: settings, cursor: cursor}) do" },
            { "type": "add", "oldNum": null, "newNum": 6,  "text": "    url = Map.fetch!(settings, \"url\")" },
            { "type": "add", "oldNum": null, "newNum": 7,  "text": "    headers = build_headers(settings)" },
            { "type": "add", "oldNum": null, "newNum": 8,  "text": "    params = build_params(settings, cursor)" },
            { "type": "add", "oldNum": null, "newNum": 9,  "text": "" },
            { "type": "add", "oldNum": null, "newNum": 10, "text": "    case Req.get(url, headers: headers, params: params) do" },
            { "type": "add", "oldNum": null, "newNum": 11, "text": "      {:ok, %{status: 200, body: body}} -> {:ok, body}" },
            { "type": "add", "oldNum": null, "newNum": 12, "text": "      {:ok, %{status: status}}          -> {:error, {:http_error, status}}" },
            { "type": "add", "oldNum": null, "newNum": 13, "text": "      {:error, reason}                  -> {:error, reason}" },
            { "type": "add", "oldNum": null, "newNum": 14, "text": "    end" },
            { "type": "add", "oldNum": null, "newNum": 15, "text": "  end" },
            { "type": "add", "oldNum": null, "newNum": 16, "text": "" },
            { "type": "add", "oldNum": null, "newNum": 17, "text": "  # No cursor — first run, fetch from beginning" },
            { "type": "add", "oldNum": null, "newNum": 18, "text": "  defp build_params(settings, nil) do" },
            { "type": "add", "oldNum": null, "newNum": 19, "text": "    %{limit: Map.get(settings, \"page_size\", 100)}" },
            { "type": "add", "oldNum": null, "newNum": 20, "text": "  end" },
            { "type": "add", "oldNum": null, "newNum": 21, "text": "" },
            { "type": "add", "oldNum": null, "newNum": 22, "text": "  # Cursor present — incremental fetch from last watermark" },
            { "type": "add", "oldNum": null, "newNum": 23, "text": "  defp build_params(settings, cursor) do" },
            { "type": "add", "oldNum": null, "newNum": 24, "text": "    %{" },
            { "type": "add", "oldNum": null, "newNum": 25, "text": "      since: cursor," },
            { "type": "add", "oldNum": null, "newNum": 26, "text": "      limit: Map.get(settings, \"page_size\", 100)" },
            { "type": "add", "oldNum": null, "newNum": 27, "text": "    }" },
            { "type": "add", "oldNum": null, "newNum": 28, "text": "  end" },
            { "type": "add", "oldNum": null, "newNum": 29, "text": "end" }
          ],
          "explanation": {
            "summary": "HTTP adapter — two-clause incremental fetch",
            "detail": "`build_params/2` dispatches on whether `cursor` is `nil` (first run, no `since` param) or a value (incremental, pass `since: cursor`). Pattern-matched clauses replace an `if cursor` branch — each clause declares exactly the params it needs.",
            "satisfies": ["req-2", "req-3"],
            "flag": null,
            "learn": {
              "language": "Elixir",
              "idiom": "multiple function clauses for pattern-based dispatch",
              "idiomatic": true,
              "learn_detail": "`build_params/2` has two heads matching on `nil` vs a bound value in the second argument. Elixir matches top-to-bottom and selects the first clause whose pattern fits — no `if/cond` chain needed. Coming from other languages this looks like function overloading.",
              "preferred": null
            }
          }
        }
      ]
    },
