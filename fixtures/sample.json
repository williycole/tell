            { "type": "add", "oldNum": null, "newNum": 13, "text": "    iv = :crypto.strong_rand_bytes(@iv_bytes)" },
            { "type": "add", "oldNum": null, "newNum": 14, "text": "" },
            { "type": "add", "oldNum": null, "newNum": 15, "text": "    {ciphertext, tag} =" },
            { "type": "add", "oldNum": null, "newNum": 16, "text": "      :crypto.crypto_one_time_aead(:aes_256_gcm, key, iv, plaintext, @aad, @tag_bytes, true)" },
